---

---

<div
    class="card"
    style="overflow-x: auto;border: 1px solid rgb(229, 231, 235); padding: 1rem; margin-bottom: 1rem; box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05); border-radius: 0.5rem;"
>
    <h2>Divisor / Subnetting IPv4</h2>
    <p>
        Divide una red base en subredes de igual tamaño (FLSM), especificando la
        cantidad de subconjuntos necesarios.
    </p>

    <div
        id="splitter-error-msg"
        style="color:red; margin-bottom: 0.5rem; white-space: pre-line;"
    >
    </div>
    <div
        id="splitter-warning-msg"
        style="color:darkorange;  margin-bottom: 0.5rem; white-space: pre-line;"
    >
    </div>

    <table
        class="table table-striped table-bordered table-sm w-100"
        style="margin-bottom: 1rem;"
    >
        <tbody>
            <tr>
                <td style="width: 30%"
                    ><b>Red base (IP/CIDR o IP Máscara)</b></td
                >
                <td>
                    <input
                        id="splitter-netInput"
                        value=""
                        class="calc-input"
                        autocomplete="off"
                        spellcheck="false"
                        placeholder="Ej: 192.168.1.0/24 o 192.168.1.0 255.255.255.0"
                    />
                </td>
            </tr>
            <tr>
                <td><b>Cantidad de subredes requeridas</b></td>
                <td>
                    <input
                        id="splitter-countInput"
                        type="number"
                        min="1"
                        value="4"
                        class="calc-input"
                        autocomplete="off"
                    />
                </td>
            </tr>
        </tbody>
    </table>

    <table
        class="table table-striped table-bordered table-sm w-100"
        id="splitter-results-table"
        style="display:none; margin-bottom: 1rem;"
    >
        <thead style="background-color: rgba(0,0,0,0.03);">
            <tr>
                <td colspan="4">
                    <span
                        id="splitter-base-info"
                        style="font-weight:bold; color:#0f172a;"></span>
                    <br />
                    <span
                        id="splitter-sub-info"
                        style="font-size: 0.9em; color:#475569;"></span>
                </td>
            </tr>
            <tr>
                <th style="width: 10%;">Número de red</th>
                <th style="width: 25%;">Red de la Subred</th>
                <th style="width: 40%;">Rango de Hosts útiles</th>
                <th style="width: 25%;">Broadcast</th>
            </tr>
        </thead>
        <tbody id="splitter-tbody">
            <!-- Table rows injected here -->
        </tbody>
    </table>

    <style>
        .calc-input {
            padding: 0;
            border: none;
            border-bottom: 1px dotted transparent;
            border-radius: 0;
            width: 100%;
            font-family: inherit;
            font-size: inherit;
            background-color: transparent;
            color: inherit;
            outline: none;
            transition: border-color 0.2s;
        }

        .calc-input:hover {
            border-bottom-color: #cbd5e1;
            cursor: text;
        }
        .calc-input:focus {
            border-bottom-style: solid;
            border-bottom-color: #3b82f6;
        }

        table {
            border-collapse: collapse;
            width: 100%;
            table-layout: fixed;
        }
        table td,
        table th {
            vertical-align: middle;
            padding: 0.5rem;
            word-wrap: break-word;
        }
        .table-bordered td,
        .table-bordered th {
            border: 1px solid #dee2e6;
        }
        .table-striped tbody tr:nth-of-type(odd) {
            background-color: rgba(0, 0, 0, 0.02);
        }
        #splitter-results-table th {
            color: #475569;
            font-weight: 600;
        }
        #splitter-tbody td {
            text-align: center;
        }
        .text-muted {
            color: #9ca3af !important;
            font-style: italic;
        }
    </style>

    <script type="module">
        const netEl = document.getElementById("splitter-netInput");
        const countEl = document.getElementById("splitter-countInput");
        const errEl = document.getElementById("splitter-error-msg");
        const warnEl = document.getElementById("splitter-warning-msg");
        const tbody = document.getElementById("splitter-tbody");
        const resultsTable = document.getElementById("splitter-results-table");
        const baseInfoEl = document.getElementById("splitter-base-info");
        const subInfoEl = document.getElementById("splitter-sub-info");

        function ipToInt(ip) {
            const parts = ip
                .trim()
                .split(".")
                .map((n) => parseInt(n, 10));
            if (
                parts.length !== 4 ||
                parts.some((p) => Number.isNaN(p) || p < 0 || p > 255)
            ) {
                return null;
            }
            return (
                (((parts[0] << 24) >>> 0) +
                    ((parts[1] << 16) >>> 0) +
                    ((parts[2] << 8) >>> 0) +
                    (parts[3] >>> 0)) >>>
                0
            );
        }

        function intToIp(i) {
            return [
                (i >>> 24) & 255,
                (i >>> 16) & 255,
                (i >>> 8) & 255,
                i & 255,
            ].join(".");
        }

        function maskToPrefix(mask) {
            mask = mask.trim();
            if (mask.startsWith("/")) {
                const p = parseInt(mask.slice(1), 10);
                return Number.isNaN(p) || p < 0 || p > 32 ? null : p;
            }
            if (/^[0-9.]+$/.test(mask)) {
                const m = ipToInt(mask);
                if (m === null) return null;
                let c = 0;
                for (let i = 31; i >= 0; i--) {
                    if (((m >>> i) & 1) === 1) c++;
                    else break;
                }
                return c;
            }
            return null;
        }

        function prefixToMaskInt(prefix) {
            if (prefix === 0) return 0;
            return ((0xffffffff << (32 - prefix)) >>> 0) >>> 0;
        }

        function compute() {
            try {
                const raw = netEl.value.trim();
                errEl.textContent = "";
                warnEl.textContent = "";
                tbody.innerHTML = "";
                resultsTable.style.display = "none";
                baseInfoEl.textContent = "";
                subInfoEl.textContent = "";

                if (!raw) return;

                let ipPart = raw;
                let prefix = null;

                // Parse format "192.168.1.0/24" vs "192.168.1.0 255.255.255.0"
                if (raw.includes("/")) {
                    const [a, p] = raw.split("/");
                    ipPart = a.trim();
                    prefix = parseInt(p.trim(), 10);
                } else if (raw.includes(" ")) {
                    const [a, m] = raw.split(/\s+/);
                    ipPart = a.trim();
                    prefix = maskToPrefix(m.trim());
                } else {
                    // Try to guess or show error
                    throw new Error(
                        "Agrega la máscara o el prefijo, ej: 192.168.1.0/24",
                    );
                }

                if (
                    prefix === null ||
                    Number.isNaN(prefix) ||
                    prefix < 0 ||
                    prefix > 32
                ) {
                    throw new Error(
                        "El prefijo o la máscara indicados no son válidos.",
                    );
                }

                const ipInt = ipToInt(ipPart);
                if (ipInt === null) {
                    throw new Error(
                        "La dirección IPv4 de la red base no es válida.",
                    );
                }

                const count = parseInt(countEl.value, 10);
                if (isNaN(count) || count < 1) {
                    throw new Error(
                        "La cantidad de subredes debe ser al menos 1.",
                    );
                }

                // Get base network
                const maskInt = prefixToMaskInt(prefix);
                const network = (ipInt & maskInt) >>> 0;

                if (ipInt !== network) {
                    warnEl.textContent = `Aviso: La IP introducida (${intToIp(ipInt)}) no es dirección de red pura, ajustada internamente a la red base ${intToIp(network)}/${prefix}.`;
                }

                const needed = Math.ceil(Math.log2(count));
                const actualSubnets = Math.pow(2, needed);
                const newPrefix = prefix + needed;

                if (newPrefix > 32) {
                    throw new Error(
                        `¡Imposible dividir en tantas subredes! La máscara requerida sería /${newPrefix}, lo cual excede el límite de /32.`,
                    );
                }

                const newBlock = Math.pow(2, 32 - newPrefix);

                if (actualSubnets !== count) {
                    warnEl.textContent +=
                        (warnEl.textContent ? "\n" : "") +
                        `Nota: se han generado automáticamente ${actualSubnets} subredes (potencia de 2 más cercana) para poder cubrir las ${count} solicitadas.`;
                }

                let hostsPerSubnet = 0;
                if (newPrefix >= 31) hostsPerSubnet = newPrefix === 32 ? 1 : 2;
                else hostsPerSubnet = Math.pow(2, 32 - newPrefix) - 2;

                baseInfoEl.textContent = `Subnetting de la Red: ${intToIp(network)}/${prefix} (${intToIp(maskInt)})`;
                subInfoEl.textContent = `Nuevas Redes Creadas: ${actualSubnets} subredes. Nueva máscara asignada: /${newPrefix} (${intToIp(prefixToMaskInt(newPrefix))}). Hosts útiles por subred: ${hostsPerSubnet}.`;

                let htmlContent = "";
                const MAX_RENDER = 1000; // Protegernos de crashes si se piden miles de subredes

                let renderLimit = Math.min(actualSubnets, MAX_RENDER);

                for (let i = 0; i < renderLimit; i++) {
                    const net = (network + i * newBlock) >>> 0;
                    const broadcast = (net + newBlock - 1) >>> 0;

                    const first =
                        newPrefix === 32
                            ? net
                            : newPrefix === 31
                              ? net
                              : (net + 1) >>> 0;
                    const last =
                        newPrefix === 32
                            ? net
                            : newPrefix === 31
                              ? (net + 1) >>> 0
                              : (broadcast - 1) >>> 0;

                    const firstIp = intToIp(first);
                    const lastIp = intToIp(last);
                    const rangeDisplay =
                        newPrefix >= 31
                            ? `${firstIp}`
                            : `${firstIp} - ${lastIp}`;

                    htmlContent += `
                        <tr>
                            <td><b>${i + 1}</b></td>
                            <td>${intToIp(net)}/${newPrefix}</td>
                            <td>${rangeDisplay}</td>
                            <td>${newPrefix >= 31 ? "N/A" : intToIp(broadcast)}</td>
                        </tr>
                    `;
                }

                if (actualSubnets > MAX_RENDER) {
                    htmlContent += `
                        <tr>
                            <td colspan="4" class="text-muted">... se han omitido ${actualSubnets - MAX_RENDER} subredes adicionales por rendimiento visual ...</td>
                        </tr>
                    `;
                }

                tbody.innerHTML = htmlContent;
                resultsTable.style.display = "table";
            } catch (e) {
                errEl.textContent = "Error: " + e.message;
            }
        }

        netEl.addEventListener("input", compute);
        countEl.addEventListener("input", compute);

        // Initial render if pre-filled
        compute();
    </script>
</div>
