---

---

<div
    class="card"
    style="overflow-x: auto;border: 1px solid rgb(229, 231, 235); padding: 1rem; margin-bottom: 1rem; box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05); border-radius: 0.5rem;"
>
    <h2>Agrupador IPv4 (Supernetting)</h2>
    <p>
        Agrupa ("supernetting") un conjunto de direcciones IPv4, encontrando la
        red más pequeña que engloba a todas las direcciones.
    </p>
    <p>
        Introduce una lista de direcciones IPv4 (separadas por línea, espacio o
        coma).
    </p>

    <div
        id="grouper-error-msg"
        style="color:red; margin-bottom: 0.5rem; white-space: pre-line;"
    >
    </div>
    <div
        id="grouper-warning-msg"
        style="color:darkorange;  margin-bottom: 0.5rem; white-space: pre-line;"
    >
    </div>

    <div style="margin-bottom: 1rem;">
        <textarea
            id="grouper-ipListInput"
            rows="5"
            class="calc-input"
            style="width: 100%; box-sizing: border-box; resize: vertical; padding: 0.5rem; border: 1px solid #dee2e6; border-radius: 0.25rem;"
            placeholder="Ej: 192.168.1.1
192.168.1.200
192.168.2.5"
            autocomplete="off"
            spellcheck="false"></textarea>
    </div>

    <table class="table table-striped table-bordered table-sm w-100">
        <tbody>
            <tr>
                <td><b>Red (Supernet)</b></td>
                <td><span id="supernetResult"></span></td>
                <td><span id="supernetResultBinary"></span></td>
            </tr>
            <tr>
                <td><b>Máscara de red (Supernet)</b></td>
                <td><span id="supernetMask"></span></td>
                <td><span id="supernetMaskBinary"></span></td>
            </tr>
            <tr>
                <td><b>Primer anfitrión</b></td>
                <td><span id="grouper-hostMin"></span></td>
                <td><span id="grouper-hostMinBinary"></span></td>
            </tr>
            <tr>
                <td><b>Último anfitrión</b></td>
                <td><span id="grouper-hostMax"></span></td>
                <td><span id="grouper-hostMaxBinary"></span></td>
            </tr>
            <tr>
                <td><b>Anfitriones en red</b></td>
                <td><span id="grouper-hostsNet"></span></td>
                <td></td>
            </tr>
            <tr>
                <td><b>Dirección de Difusión</b></td>
                <td><span id="supernetBroadcast"></span></td>
                <td><span id="supernetBroadcastBinary"></span></td>
            </tr>
            <tr>
                <td><b>IPs válidas analizadas</b></td>
                <td><span id="supernetTotalParsed"></span></td>
                <td></td>
            </tr>
        </tbody>
    </table>

    <style>
        .calc-input {
            font-family: inherit;
            font-size: inherit;
            outline: none;
            transition: border-color 0.2s;
        }
        .calc-input:hover {
            border-color: #cbd5e1;
        }
        .calc-input:focus {
            border-color: #3b82f6 !important;
            box-shadow: 0 0 0 1px #3b82f6;
        }

        table {
            border-collapse: collapse;
            width: 100%;
            table-layout: fixed;
        }
        table td,
        table th {
            vertical-align: middle;
            padding: 0.5rem;
            word-wrap: break-word;
        }
        .table-bordered td,
        .table-bordered th {
            border: 1px solid #dee2e6;
        }
        .table-striped tbody tr:nth-of-type(odd) {
            background-color: rgba(0, 0, 0, 0.02);
        }
        table td:first-child {
            width: 20%;
        }
        table td:nth-child(2) {
            width: 40%;
        }
        table td:nth-child(3) {
            width: 40%;
            color: #64748b;
        }
        .text-muted {
            color: #9ca3af !important;
            font-style: italic;
        }
    </style>

    <script type="module">
        const elIpList = document.getElementById("grouper-ipListInput");
        const errEl = document.getElementById("grouper-error-msg");
        const warnEl = document.getElementById("grouper-warning-msg");

        function parseIp(ip) {
            if (!ip) return null;
            let parts = ip.trim().split(".");
            // Si el usuario escribe "192." ignorar el último punto vacío
            if (parts.length > 0 && parts[parts.length - 1] === "") {
                parts.pop();
            }
            if (parts.length === 0 || parts.length > 4) return null;
            const parsed = parts.map((n) => parseInt(n));
            if (parsed.some((p) => isNaN(p) || p < 0 || p > 255)) return null;

            // Rellenar con ceros (ej: 192.168 -> 192.168.0.0)
            while (parsed.length < 4) parsed.push(0);
            return (
                ((parsed[0] << 24) >>> 0) +
                ((parsed[1] << 16) >>> 0) +
                ((parsed[2] << 8) >>> 0) +
                (parsed[3] >>> 0)
            );
        }

        function intToIp(i) {
            return [
                (i >>> 24) & 255,
                (i >>> 16) & 255,
                (i >>> 8) & 255,
                i & 255,
            ].join(".");
        }

        function toBinary(i) {
            return [
                (i >>> 24) & 255,
                (i >>> 16) & 255,
                (i >>> 8) & 255,
                i & 255,
            ]
                .map((b) => b.toString(2).padStart(8, "0"))
                .join(".");
        }

        function prefixToMaskInt(prefix) {
            if (prefix === 0) return 0;
            return (0xffffffff << (32 - prefix)) >>> 0;
        }

        function setEl(id, text, isMuted = false) {
            const el = document.getElementById(id);
            if (!el) return;
            el.textContent = text;
            if (isMuted) el.classList.add("text-muted");
            else el.classList.remove("text-muted");
        }

        function clearOutputs() {
            setEl("supernetResult", "");
            setEl("supernetResultBinary", "");
            setEl("supernetMask", "");
            setEl("supernetMaskBinary", "");
            setEl("grouper-hostMin", "");
            setEl("grouper-hostMinBinary", "");
            setEl("grouper-hostMax", "");
            setEl("grouper-hostMaxBinary", "");
            setEl("grouper-hostsNet", "");
            setEl("supernetBroadcast", "");
            setEl("supernetBroadcastBinary", "");
            setEl("supernetTotalParsed", "");
        }

        function compute() {
            try {
                const text = elIpList.value;
                errEl.textContent = "";
                warnEl.textContent = "";

                if (!text.trim()) {
                    clearOutputs();
                    return;
                }

                // Extraer IPs
                const rawIps = text.split(/[\s,-]+/);
                const uniqueIps = new Set();
                const validIps = [];
                const errors = [];
                let duplicateCount = 0;

                for (let raw of rawIps) {
                    if (!raw) continue;
                    // Limpiamos posibles prefijos o espacios
                    const ipPart = raw.split("/")[0].trim();
                    if (!ipPart) continue;
                    const parsed = parseIp(ipPart);
                    if (parsed !== null) {
                        const firstOctet = (parsed >>> 24) & 0xff;
                        // Comprobar si es IP reservada (0.x.x.x, 127.x.x.x, Multicast/Experimental >= 224, 255.255.255.255)
                        if (
                            firstOctet === 0 ||
                            firstOctet === 127 ||
                            firstOctet >= 224 ||
                            parsed === 0xffffffff
                        ) {
                            errors.push(
                                `IP reservada/no válida agrupada: ${ipPart}`,
                            );
                            continue;
                        }

                        if (uniqueIps.has(parsed)) {
                            duplicateCount++;
                        } else {
                            uniqueIps.add(parsed);
                            validIps.push(parsed);
                        }
                    } else {
                        errors.push(`IP con formato incorrecto: ${ipPart}`);
                    }
                }

                if (duplicateCount > 0) {
                    warnEl.textContent = `Aviso: Se ignoraron ${duplicateCount} IP(s) duplicada(s).`;
                }

                if (errors.length > 0) {
                    errEl.textContent = errors.join("\n");
                }

                if (validIps.length === 0) {
                    clearOutputs();
                    return;
                }

                setEl("supernetTotalParsed", uniqueIps.size.toString());

                // Supernetting logic usando el mayor y menor
                let minIp = validIps[0];
                let maxIp = validIps[0];
                for (let i = 1; i < validIps.length; i++) {
                    if (validIps[i] < minIp) minIp = validIps[i];
                    if (validIps[i] > maxIp) maxIp = validIps[i];
                }

                const xor = (minIp ^ maxIp) >>> 0;
                let prefix;
                if (xor === 0) {
                    prefix = 32;
                } else {
                    prefix = Math.clz32(xor);
                }

                const maskInt = prefixToMaskInt(prefix);
                const network = (minIp & maskInt) >>> 0;
                const broadcast = (network | (~maskInt >>> 0)) >>> 0;

                setEl("supernetResult", `${intToIp(network)}/${prefix}`);
                setEl("supernetResultBinary", toBinary(network));

                setEl("supernetMask", `${intToIp(maskInt)} (/${prefix})`);
                setEl("supernetMaskBinary", toBinary(maskInt));

                let hostsCount;
                if (prefix >= 31) hostsCount = prefix === 32 ? 1 : 2;
                else hostsCount = Math.pow(2, 32 - prefix) - 2;
                setEl("grouper-hostsNet", hostsCount);

                if (prefix >= 31) {
                    const first = prefix === 32 ? network : network;
                    const last = prefix === 32 ? network : network + 1;

                    setEl("grouper-hostMin", intToIp(first));
                    setEl("grouper-hostMinBinary", toBinary(first));
                    setEl("grouper-hostMax", intToIp(last));
                    setEl("grouper-hostMaxBinary", toBinary(last));

                    if (prefix === 31 || prefix === 32) {
                        setEl("supernetBroadcast", "N/A", true);
                        setEl("supernetBroadcastBinary", "");
                    } else {
                        setEl("supernetBroadcast", intToIp(broadcast));
                        setEl("supernetBroadcastBinary", toBinary(broadcast));
                    }
                } else {
                    setEl("grouper-hostMin", intToIp((network + 1) >>> 0));
                    setEl(
                        "grouper-hostMinBinary",
                        toBinary((network + 1) >>> 0),
                    );
                    setEl("grouper-hostMax", intToIp((broadcast - 1) >>> 0));
                    setEl(
                        "grouper-hostMaxBinary",
                        toBinary((broadcast - 1) >>> 0),
                    );
                    setEl("supernetBroadcast", intToIp(broadcast));
                    setEl("supernetBroadcastBinary", toBinary(broadcast));
                }
            } catch (e) {
                errEl.textContent = "Error inesperado: " + e.message;
            }
        }

        elIpList.addEventListener("input", compute);

        compute();
    </script>
</div>
