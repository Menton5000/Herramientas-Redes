---

---

<div
    class="card"
    style="overflow-x: auto;border: 1px solid rgb(229, 231, 235); padding: 1rem; margin-bottom: 1rem; box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05); border-radius: 0.5rem;"
>
    <h2>Calculadora IPv4</h2>
    <p>Permite calcular información de red relevante de una dirección IPv4</p>
    <p>
        Para usar la calculadora, ingresa una dirección IPv4 y una máscara de
        red (en formato decimal punteado o CIDR) en la tabla de abajo. La
        información se actualizará automáticamente a medida que escribas.
    </p>
    <div id="error-msg" style="color:red; margin-bottom: 0.5rem;"></div>
    <div id="warning-msg" style="color:darkorange;  margin-bottom: 0.5rem;">
    </div>

    <table class="table table-striped table-bordered table-sm w-100">
        <tbody>
            <tr>
                <td><b>Dirección IP</b></td>
                <td
                    ><input
                        id="ipAddress"
                        value=""
                        class="calc-input calc-ip-input"
                        autocomplete="off"
                        spellcheck="false"
                        placeholder="192.168.1.1"
                    /></td
                >
                <td><span id="ipAddressBinary"></span></td>
            </tr>

            <tr>
                <td><b>Máscara de red</b></td>
                <td>
                    <input
                        id="netMaskInput"
                        value=""
                        class="calc-input calc-mask-input"
                        autocomplete="off"
                        spellcheck="false"
                        placeholder="255.255.255.0 o /24"
                        list="maskOptions"
                    />
                    <datalist id="maskOptions">
                        <option value="/8"></option>
                        <option value="/16"></option>
                        <option value="/24"></option>
                        <option value="/25"></option>
                        <option value="/26"></option>
                        <option value="/27"></option>
                        <option value="/28"></option>
                        <option value="/29"></option>
                        <option value="/30"></option>
                        <option value="/31"></option>
                        <option value="/32"></option>
                    </datalist>
                    <span id="netMaskLabel"></span>
                </td>
                <td><span id="netMaskBinary"></span></td>
            </tr>

            <tr>
                <td><b>Wildcard</b></td>
                <td><span id="wildcard"></span></td>
                <td><span id="wildcardBinary"></span></td>
            </tr>

            <tr>
                <td><b>Clase de IP</b></td>
                <td><span id="ipClass"></span></td>
                <td></td>
            </tr>
            <tr>
                <td><b>Dirección de red</b></td>
                <td><span id="netAddress"></span></td>
                <td><span id="netAddressBinary"></span></td>
            </tr>

            <tr>
                <td><b>Dirección de Difusión</b></td>
                <td><span id="brodcastAddress"></span></td>
                <td><span id="brodcastAddressBinary"></span></td>
            </tr>

            <tr>
                <td><b>Anfitrión mínimo</b></td>
                <td><span id="hostMin"></span></td>
                <td><span id="hostMinBinary"></span></td>
            </tr>

            <tr>
                <td><b>Anfitrión máximo</b></td>
                <td><span id="hostMax"></span></td>
                <td><span id="hostMaxBinary"></span></td>
            </tr>

            <tr>
                <td><b>Anfitriones en red</b></td>
                <td><span id="hostsNet"></span></td>
                <td></td>
            </tr>

            <tr>
                <td><b>Notas</b></td>
                <td colspan="2"><span id="networkNotes"></span></td>
            </tr>
        </tbody>
    </table>

    <style>
        .calc-input {
            padding: 0;
            border: none;
            border-bottom: 1px dotted transparent;
            border-radius: 0;
            width: 60%;
            max-width: 100%;
            font-family: inherit;
            font-size: inherit;
            background-color: transparent;
            color: inherit;
            outline: none;
            transition: border-color 0.2s;
        }

        .calc-input:hover {
            border-bottom-color: #cbd5e1;
            cursor: text;
        }
        .calc-input:focus {
            border-bottom-style: solid;
            border-bottom-color: #3b82f6;
        }
        table {
            border-collapse: collapse;
            width: 100%;
            table-layout: fixed;
        }
        table td,
        table th {
            vertical-align: middle;
            padding: 0.5rem;
            word-wrap: break-word;
        }
        .table-bordered td,
        .table-bordered th {
            border: 1px solid #dee2e6;
        }
        .table-striped tbody tr:nth-of-type(odd) {
            background-color: rgba(0, 0, 0, 0.02);
        }
        table td:first-child {
            width: 20%;
        }
        table td:nth-child(2) {
            width: 40%;
        }
        table td:nth-child(3) {
            width: 40%;
            color: #64748b;
        }
        .text-muted {
            color: #9ca3af !important;
            font-style: italic;
        }
    </style>

    <script type="module">
        const elIp = document.getElementById("ipAddress");
        const elMask = document.getElementById("netMaskInput");
        const errEl = document.getElementById("error-msg");
        const warnEl = document.getElementById("warning-msg");

        function parseIp(ip) {
            if (!ip) return null;
            let parts = ip.trim().split(".");
            // Si el usuario escribe "192." ignorar el último punto vacío
            if (parts.length > 0 && parts[parts.length - 1] === "") {
                parts.pop();
            }
            if (parts.length === 0 || parts.length > 4) return null;
            const parsed = parts.map((n) => parseInt(n));
            if (parsed.some((p) => isNaN(p) || p < 0 || p > 255)) return null;

            // Rellenar con ceros (ej: 192.168 -> 192.168.0.0)
            while (parsed.length < 4) parsed.push(0);
            return (
                ((parsed[0] << 24) >>> 0) +
                ((parsed[1] << 16) >>> 0) +
                ((parsed[2] << 8) >>> 0) +
                (parsed[3] >>> 0)
            );
        }

        function intToIp(i) {
            return [
                (i >>> 24) & 255,
                (i >>> 16) & 255,
                (i >>> 8) & 255,
                i & 255,
            ].join(".");
        }

        function toBinary(i) {
            return [
                (i >>> 24) & 255,
                (i >>> 16) & 255,
                (i >>> 8) & 255,
                i & 255,
            ]
                .map((b) => b.toString(2).padStart(8, "0"))
                .join(".");
        }

        function maskToPrefix(mask) {
            mask = mask.trim();
            if (!mask) return null;
            if (mask.startsWith("/")) {
                const p = parseInt(mask.slice(1));
                if (isNaN(p) || p < 0 || p > 32) return null;
                return p;
            }
            if (/^[0-9.]+$/.test(mask)) {
                const m = parseIp(mask);
                if (m === null) return null;
                let c = 0;
                for (let i = 31; i >= 0; i--) {
                    if ((m >>> i) & 1) c++;
                    else break;
                }
                return c;
            }
            return null;
        }

        function prefixToMaskInt(prefix) {
            if (prefix === 0) return 0;
            return (0xffffffff << (32 - prefix)) >>> 0;
        }

        function setEl(id, text, isMuted = false) {
            const el = document.getElementById(id);
            if (!el) return;
            el.textContent = text;
            if (isMuted) el.classList.add("text-muted");
            else el.classList.remove("text-muted");
        }

        function clearIpOutputs() {
            setEl("ipAddressBinary", "");
            setEl("ipClass", "");
        }

        function clearMaskOutputs() {
            setEl("netMaskLabel", "");
            setEl("netMaskBinary", "");
            setEl("wildcard", "");
            setEl("wildcardBinary", "");
            setEl("hostsNet", "");
        }

        function clearCombinedOutputs() {
            setEl("netAddress", "");
            setEl("netAddressBinary", "");
            setEl("brodcastAddress", "");
            setEl("brodcastAddressBinary", "");
            setEl("hostMin", "");
            setEl("hostMinBinary", "");
            setEl("hostMax", "");
            setEl("hostMaxBinary", "");
        }

        function compute() {
            try {
                const ipv = elIp.value.trim();
                const maskv = elMask.value.trim();

                errEl.textContent = "";
                warnEl.textContent = "";

                if (!ipv && !maskv) {
                    clearIpOutputs();
                    clearMaskOutputs();
                    clearCombinedOutputs();
                    setEl("networkNotes", "Ninguna", true);
                    return;
                }

                let ipInt = null;
                if (ipv) {
                    ipInt = parseIp(ipv);
                    if (ipInt === null)
                        throw new Error("Dirección IPv4 inválida");
                }

                let prefix = null;
                if (maskv) {
                    prefix = maskToPrefix(maskv);
                    if (prefix === null) throw new Error("Máscara inválida");
                }

                // Inferir máscara a base de IPs especiales si el usuario no introduce una
                if (ipInt !== null && prefix === null && !maskv) {
                    const firstOctet = (ipInt >>> 24) & 0xff;
                    if (ipInt === 0xffffffff)
                        prefix = 32; // 255.255.255.255
                    else if (firstOctet === 127)
                        prefix = 8; // 127.x.x.x Loopback
                    else if (firstOctet === 0) prefix = 8; // 0.x.x.x This network
                }

                const notes = [];

                // LÓGICA IP
                if (ipInt !== null) {
                    const firstOctet = (ipInt >>> 24) & 0xff;
                    let cls = "";
                    if (firstOctet <= 127) cls = "A";
                    else if (firstOctet <= 191) cls = "B";
                    else if (firstOctet <= 223) cls = "C";
                    else if (firstOctet <= 239) cls = "D";
                    else cls = "E";

                    if (firstOctet === 127) notes.push("Loopback");
                    if (firstOctet === 10) notes.push("Privada");
                    if (firstOctet === 172) {
                        const second = (ipInt >>> 16) & 0xff;
                        if (second >= 16 && second <= 31) notes.push("Privada");
                    }
                    if (firstOctet === 192) {
                        const second = (ipInt >>> 16) & 0xff;
                        if (second === 168) notes.push("Privada");
                    }
                    if (firstOctet === 169) {
                        const second = (ipInt >>> 16) & 0xff;
                        if (second >= 254 && second <= 254)
                            notes.push("Link-local");
                    }
                    if (firstOctet === 0) notes.push("This network");
                    if (firstOctet >= 224 && firstOctet <= 239)
                        notes.push("Multicast");
                    if (firstOctet >= 240 && firstOctet <= 255)
                        notes.push("Reservado - Experimental");
                    if (ipInt === 0xffffffff) notes.push("Limited broadcast");

                    setEl("ipAddressBinary", toBinary(ipInt));
                    setEl("ipClass", `Clase ${cls}`);
                } else {
                    clearIpOutputs();
                }

                // LÓGICA MÁSCARA
                let maskInt = null;
                if (prefix !== null) {
                    maskInt = prefixToMaskInt(prefix) >>> 0;
                    if (maskv && maskv.startsWith("/")) {
                        setEl("netMaskLabel", `= ${intToIp(maskInt)}`);
                    } else if (maskv) {
                        setEl("netMaskLabel", `= /${prefix}`);
                    } else {
                        setEl(
                            "netMaskLabel",
                            `(Inferida) = /${prefix} = ${intToIp(maskInt)}`,
                            true,
                        );
                    }

                    setEl("netMaskBinary", toBinary(maskInt));

                    const wildcardInt = ~maskInt >>> 0;
                    setEl("wildcard", intToIp(wildcardInt));
                    setEl("wildcardBinary", toBinary(wildcardInt));

                    let hostsCount;
                    if (prefix >= 31) hostsCount = prefix === 32 ? 1 : 2;
                    else hostsCount = Math.pow(2, 32 - prefix) - 2;
                    setEl("hostsNet", hostsCount);

                    if (prefix === 31 || prefix === 32) {
                        warnEl.textContent = `Aviso: Una máscara de /${prefix} resulta en redes sin hosts (se suele utilizar en enlaces Point-to-Point o Loopbacks). Es por ello que no se reservan direcciones para red ni broadcast.`;
                    }
                } else {
                    clearMaskOutputs();
                }

                // LÓGICA COMBINADA (Requiere IP y Máscara)
                if (ipInt !== null && prefix !== null) {
                    const network = (ipInt & maskInt) >>> 0;
                    const broadcast = (network | (~maskInt >>> 0)) >>> 0;

                    if (prefix === 31) notes.push("Punto a punto (RFC 3021)");
                    if (prefix === 32)
                        notes.push("Host único (Loopback/Host route)");
                    if (prefix < 31 && ipInt === network)
                        notes.push("La IP es dirección de red");
                    if (prefix < 31 && ipInt === broadcast)
                        notes.push("La IP es dirección de broadcast");

                    const first =
                        prefix === 32
                            ? network
                            : prefix === 31
                              ? network
                              : network + 1;
                    const last =
                        prefix === 32
                            ? network
                            : prefix === 31
                              ? network + 1
                              : broadcast - 1;

                    if (prefix >= 31) {
                        setEl("netAddress", "N/A", true);
                        setEl("netAddressBinary", "");
                        setEl("brodcastAddress", "N/A", true);
                        setEl("brodcastAddressBinary", "");
                    } else {
                        setEl("netAddress", `${intToIp(network)}/${prefix}`);
                        setEl("netAddressBinary", toBinary(network));
                        setEl("brodcastAddress", intToIp(broadcast));
                        setEl("brodcastAddressBinary", toBinary(broadcast));
                    }

                    setEl("hostMin", intToIp(first));
                    setEl("hostMinBinary", toBinary(first));
                    setEl("hostMax", intToIp(last));
                    setEl("hostMaxBinary", toBinary(last));
                } else {
                    clearCombinedOutputs();
                }

                // Asignar bloque de notas al final
                if (notes.length) {
                    setEl("networkNotes", notes.join(" | "));
                } else {
                    if (ipInt !== null || prefix !== null) {
                        setEl("networkNotes", "Ninguna", true);
                    } else {
                        setEl("networkNotes", "", true);
                    }
                }
            } catch (e) {
                errEl.textContent = "Error: " + e.message;
                warnEl.textContent = "";
            }
        }

        elIp.addEventListener("input", compute);
        elMask.addEventListener("input", compute);

        compute();
    </script>
</div>
